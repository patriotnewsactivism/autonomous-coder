# ── AI Providers (all OpenAI-compatible except Gemini & Cohere) ─────────────

# DeepSeek (primary — best for coding, cheapest)
DEEPSEEK_API_KEY=your_deepseek_api_key
DEEPSEEK_MODEL=deepseek-chat
# DEEPSEEK_ENDPOINT=https://api.deepseek.com/v1/chat/completions

# Groq (free tier — fastest inference, 30 RPM, 1000 RPD)
GROQ_API_KEY=your_groq_api_key
GROQ_MODEL=llama-3.3-70b-versatile
# GROQ_ENDPOINT=https://api.groq.com/openai/v1/chat/completions

# Google Gemini (free tier — 10-15 RPM, 1000-1500 RPD, 1M context)
# IMPORTANT: Do NOT enable billing on this Google Cloud project or the free tier disappears!
GEMINI_API_KEY=your_gemini_api_key

# Cerebras (free tier — ~1M tokens/day, 30 RPM, ultra-fast)
CEREBRAS_API_KEY=your_cerebras_api_key
# CEREBRAS_ENDPOINT=https://api.cerebras.ai/v1/chat/completions

# GitHub Models (free tier — 10-15 RPM, 50-150 RPD, no credit card)
# Uses a standard GitHub Personal Access Token
GITHUB_TOKEN=your_github_pat
# GITHUB_MODELS_TOKEN=same_as_above

# Cohere (free trial — 1000 calls/month, 20 RPM)
COHERE_API_KEY=your_cohere_api_key

# ── Database ────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ── Frontend (Vite) ────────────────────────────────────────────────────────
VITE_SUPABASE_PROJECT_ID=your_project_id
VITE_SUPABASE_PUBLISHABLE_KEY=your_anon_key
VITE_SUPABASE_URL=https://your-project.supabase.co

# ── Optional: Notifications ────────────────────────────────────────────────
# RESEND_API_KEY=your_resend_key
# NOTIFY_EMAIL=alerts@yourdomain.com
# NOTIFY_TO_EMAIL=you@yourdomain.com
# SLACK_NOTIFY_WEBHOOK=https://hooks.slack.com/services/...
GOOGLE_API_KEY=""  # Google Gemini API key (free tier at aistudio.google.com/apikey)

# ── Security (optional) ────────────────────────────────────────────────────────
# Set AUTH_REQUIRED=true to enable API key authentication on all /api routes.
# Clients must send:  Authorization: Bearer <key>  or  X-API-Key: <key>
# AUTH_REQUIRED=true
# API_SECRET_KEY=change-me-to-a-long-random-string
